{
  "name": "simsoft/slim",
  "description": "A fluent routing wrapper for Slim Framework 4 with simplified request/response helpers, middleware, error handling, API resources, and DataTable support",
  "keywords": [
    "slim",
    "slim4",
    "slimframework",
    "routing",
    "router",
    "middleware",
    "psr-7",
    "psr-15",
    "cors",
    "error-handler",
    "api-resource",
    "datatable",
    "rest",
    "api",
    "php",
    "simsoft"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "V.Zang, Loo",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/simsoft/slim",
  "support": {
    "issues": "https://github.com/simsoft/slim/issues",
    "source": "https://github.com/simsoft/slim"
  },
  "require": {
    "php": ">=8.2",
    "slim/psr7": "^1.7",
    "slim/slim": "^4"
  },
  "require-dev": {
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^1.11",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Simsoft\\Slim\\": "src",
      "Simsoft\\Resource\\": "src/Resource"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Simsoft\\Slim\\Tests\\": "tests",
      "Example\\": "example"
    }
  },
  "scripts": {
    "test": "phpunit --display-deprecations --display-warnings tests",
    "qc": [
      "phpstan analyse --memory-limit=512M",
      "phpmd src text phpmd.xml"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
